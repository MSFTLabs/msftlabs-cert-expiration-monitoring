                { "name": "DraftRequestParameters", "isOptional": true },
                { "name": "Query", "value": "let appCreds = AppRegistrationCredentialExpiry_CL\n| summarize arg_max(TimeGenerated, *) by ApplicationId, CredentialKeyId\n| where CredentialType != 'None'\n| extend Source = 'AppReg';\nlet kvItems = KeyVaultCredentialInventory_CL\n| summarize arg_max(TimeGenerated, *) by VaultName, ItemType, ItemName\n| where HasExpiration == true\n| extend Source = 'KeyVault';\nlet combined = union\n  (appCreds | project Source, DaysToExpiry),\n  (kvItems  | project Source, DaysToExpiry);\nlet r30  = combined | where DaysToExpiry >= 0 and DaysToExpiry <= 30  | summarize Count = count() by Source | extend Band = '\u2264 30 Days';\nlet r60  = combined | where DaysToExpiry > 30 and DaysToExpiry <= 60  | summarize Count = count() by Source | extend Band = '31\u201360 Days';\nlet r90  = combined | where DaysToExpiry > 60 and DaysToExpiry <= 90  | summarize Count = count() by Source | extend Band = '61\u201390 Days';\nlet r180 = combined | where DaysToExpiry > 90 and DaysToExpiry <= 180 | summarize Count = count() by Source | extend Band = '91\u2013180 Days';\nunion r30, r60, r90, r180\n| project Band, Source, Count\n| sort by Band asc, Source asc", "isOptional": true },
