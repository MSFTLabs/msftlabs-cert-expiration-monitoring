// Key Vault — Data Freshness
// Returns: When the most recent Key Vault data was collected and how fresh it is

KeyVaultCredentialInventory_CL
| summarize LastCollection = max(TimeGenerated)
| extend AgeMinutes = datetime_diff('minute', now(), LastCollection)
| extend AgeHours   = round(AgeMinutes / 60.0, 1)
| project LastCollection, AgeMinutes, AgeHours,
    Status = case(
        AgeHours <= 24, 'Healthy',
        AgeHours <= 48, 'Warning',
        'Stale')
